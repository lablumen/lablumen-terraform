# Per-account S3 backend config. Copy to backend.hcl (gitignored) and fill in for the target account:
#
#     cp backend.hcl.example backend.hcl
#     # set bucket = <project>-tfstate-<account_id>  (the name the bootstrap/ stack created/output)
#     terraform init -backend-config=backend.hcl
#
# The bucket name is the only account-specific value; key/region/locking/encryption are stable.

bucket       = "lablumen-tfstate-<ACCOUNT_ID>"
key          = "global/terraform.tfstate"
region       = "us-east-1"
use_lockfile = true
encrypt      = true
